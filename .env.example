# ===========================================
# Project Zeno — Environment Variables
# ===========================================
# Copy to .env and fill in your values

# --- Hedera Testnet ---
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=302e...
HEDERA_NETWORK=testnet

# --- Hedera JSON-RPC (Validation Cloud) ---
HEDERA_JSON_RPC_URL=https://testnet.hedera.validationcloud.io/v1/YOUR_API_KEY

# --- Hedera Mirror Node ---
HEDERA_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# --- Hedera Resource IDs (populated during setup) ---
ZENO_REGISTRY_TOPIC_ID=
ZENO_COMPLIANCE_TOPIC_ID=
ZENO_CALIBRATION_TOPIC_ID=
ZENO_ALERTS_TOPIC_ID=
HCS_FACILITY_TOPIC_IDS=
GGCC_TOKEN_ID=
VIOLATION_NFT_TOKEN_ID=
COMPLIANCE_CERT_NFT_TOKEN_ID=
COMPLIANCE_CHECKER_CONTRACT_ID=
PENALTY_CALCULATOR_CONTRACT_ID=

# --- AWS KMS ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
KMS_KEY_ID=
KMS_ACCOUNT_ID=

# --- Google Earth Engine ---
GEE_SERVICE_ACCOUNT_KEY_PATH=
GEE_PROJECT_ID=

# --- AI Agent (OpenAI for LangChain) ---
OPENAI_API_KEY=
